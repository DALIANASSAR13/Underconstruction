# Build submission JSON from pred_df
submission = []
for review_id, group in pred_df.groupby("review_id", sort=False):
    submission.append({
        "review_id": int(review_id),
        "aspects": group["aspect"].tolist(),
        "aspect_sentiments": dict(zip(group["aspect"], group["predicted_sentiment"]))
    })

with open("submission.json", "w", encoding="utf-8") as f:
    json.dump(submission, f, ensure_ascii=False, indent=2)

print(f"Saved {len(submission)} reviews to submission.json")
print(json.dumps(submission[:2], ensure_ascii=False, indent=2))
